<?xml version="1.0" encoding="UTF-8"?>
<!--
  phpDocumentor v3 configuration (same scope as scripts/phpdoc.sh).
  Generate HTML with: composer phpdoc
  (Direct "phpdoc -c phpdoc.xml" can fail on some setups due to URI resolution; the Composer script uses stable CLI flags.)
-->
<phpdocumentor xmlns="https://www.phpdoc.org" configVersion="3">
    <title>Laravel E-commerce — Application code</title>
    <paths>
        <output>docs/phpdoc</output>
        <cache>.phpdoc/cache</cache>
    </paths>
    <version number="1.0.0">
        <api>
            <source dsn=".">
                <path>app</path>
                <path>routes</path>
            </source>
            <output>.</output>
            <visibility>public</visibility>
            <visibility>protected</visibility>
            <default-package-name>App</default-package-name>
        </api>
    </version>
    <template name="clean"/>
</phpdocumentor>
