APP_NAME="Serralleria Solidària"
APP_ENV=local
# For checkout without Stripe/PayPal/etc.: keep APP_DEBUG=true locally. Simulated payments default ON when
# APP_ENV=local and PAYMENTS_ALLOW_SIMULATED is unset (see config/payments.php). Set PAYMENTS_ALLOW_SIMULATED=false
# if you want to force real PSP keys on your machine.
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Optional: override config("app.version") (defaults to "version" in package.json at the repo root).
# APP_VERSION=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
#
# PostgreSQL (recommended for production and local dev when matching production).
# SQLite stays the default here so PHPUnit and CI work without a server.
# Before DB_CONNECTION=pgsql: install PHP extension pdo_pgsql (e.g. php-pgsql / php8.x-pgsql).
# Without it, Artisan reports "could not find driver" (e.g. php artisan db:show).
#
# DB_CONNECTION=pgsql
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=laravel
# DB_USERNAME=postgres
# DB_PASSWORD=
# Optional: schema search path (default public).
# DB_SCHEMA=public
# TLS: prefer (default) tries SSL then falls back. Local Postgres without SSL (e.g. Docker) often needs:
# DB_SSLMODE=disable
#
# MySQL / MariaDB (optional during transition from MariaDB/MySQL)
# Requires PHP extension pdo_mysql. Use 127.0.0.1 for TCP; "localhost" often uses a Unix socket
# and can fail if mysqld only listens on TCP, or with Docker (use 127.0.0.1 or the DB service hostname).
# SQLSTATE[HY000] [2002] Network is unreachable: DB_HOST is wrong, DB is down, firewall/VPN, or bad Docker network.
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=
# PHPUnit: mysql/mariadb/pgsql use this schema name (default ecommerce_testing). For sqlite, leave unset for :memory: or set a path e.g. database/testing.sqlite
# DB_TESTING_DATABASE=ecommerce_testing

# With SQLite DB_DATABASE=:memory:, use array (or file) — database sessions need a migrated `sessions` table on the same connection.
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Transactional emails (order confirmation, installation quote, shipping, etc.) use this mailer.
# With MAIL_MAILER=log (default here) messages are written to the application log only — customers will not receive anything in their inbox.
# For real SMTP, set MAIL_MAILER=smtp and fill HOST/PORT/USERNAME/PASSWORD/ENCRYPTION. Do not leave MAIL_MAILER empty; empty values disable defaults.
#
# Gmail (App Password; 2FA on the Google account; MAIL_USERNAME and MAIL_FROM_ADDRESS should match the mailbox):
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_ENCRYPTION=tls
# MAIL_USERNAME=your-account@gmail.com
# MAIL_PASSWORD=your_16_character_app_password
# MAIL_FROM_ADDRESS=your-account@gmail.com
# MAIL_FROM_NAME="Your shop name"
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
# Use a domain-aligned address your provider accepts (SPF/DKIM as required).
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
# Visible brand line in transaction emails and image alt; independent of MAIL_FROM_NAME and framework.
# MAIL_BRAND_DISPLAY_NAME="Serralleria Solidària"
# Optional: absolute URL to override the HTML email logo (e.g. CDN). If unset, the template uses
# public/{MAIL_BRAND_DEFAULT_LOGO} (default: images/serraller_solidaria_logo_key.png).
# MAIL_BRAND_LOGO_URL=https://your-domain.example/images/serraller_solidaria_logo_key.png
# MAIL_BRAND_DEFAULT_LOGO=images/serraller_solidaria_logo_key.png
# Optional footer line under emails (contact phone/email).
# MAIL_FOOTER_CONTACT_LINE=
# Optional: ops inbox: personalized-solution "request improvements", new orders with installation quote (needs budget),
# and orders that leave checkout without confirmed payment. Omit to skip those admin emails.
# MAIL_ADMIN_NOTIFICATION_ADDRESS=ops@example.com


AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Laravel Scout (catalog search indexing). Use `null` when Elasticsearch is not configured (default for CI/SQLite).
# SCOUT_DRIVER=null
# SCOUT_PREFIX=
# SCOUT_QUEUE=false
#
# Elasticsearch (only when SCOUT_DRIVER=elasticsearch)
# ELASTICSEARCH_HOSTS=http://127.0.0.1:9200
# ELASTICSEARCH_API_KEY=
# ELASTICSEARCH_USERNAME=
# ELASTICSEARCH_PASSWORD=
# ELASTICSEARCH_RETRIES=2
# ELASTICSEARCH_REFRESH_ON_WRITE=false
# Optional integration tests against a real node:
# ES_TEST_HOST=http://127.0.0.1:9200

# Payments (PSP). Leave unset in local unless you test real checkouts.
# STRIPE_KEY=pk_test_...
# STRIPE_SECRET=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
#
# REDSYS_MERCHANT_CODE=
# REDSYS_TERMINAL=001
# REDSYS_SECRET_KEY=
# REDSYS_ENVIRONMENT=test
#
# REVOLUT_MERCHANT_API_KEY=
# REVOLUT_API_VERSION=2023-09-01
# REVOLUT_SANDBOX=true
# REVOLUT_WEBHOOK_SECRET=
#
# PayPal REST (card stays on Stripe; PayPal wallet uses PayPal directly).
# PAYPAL_CLIENT_ID=
# PAYPAL_SECRET=
# PAYPAL_MODE=sandbox
#
# Override simulated payments: omit for default (true on local, false on testing/production).
# When true with APP_DEBUG, checkout can mark payments as paid without a PSP (never in production).
# Simulated checkout applies only to non-PayPal methods without PSP keys. PayPal is never simulated: set PAYPAL_CLIENT_ID and PAYPAL_SECRET or PayPal will not appear.
# PAYMENTS_ALLOW_SIMULATED=false
#
# Demo only: allow POST checkout with checkout_demo_skip_payment=true to complete without a PSP (never enable on real production).
# CHECKOUT_DEMO_SKIP_PAYMENT=true
#
# Comma-separated methods shown at checkout / accepted by POST checkout and pay.
# Omit or leave empty for both card (Stripe) and paypal (subject to credentials and simulation rules).
# Explicit both: PAYMENTS_CHECKOUT_METHODS=card,paypal
# PayPal only (Stripe Checkout hidden even if STRIPE_* are set):
# PAYMENTS_CHECKOUT_METHODS=paypal
